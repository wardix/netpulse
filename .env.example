# NetPulse Environment Configuration Example

# Server Port (Default: 3000)
PORT=3000

# MikroTik API Request Timeout in milliseconds (Default: 5000)
MIKROTIK_TIMEOUT=5000

# Database configuration
# Use PostgreSQL by setting DATABASE_URL (example):
# DATABASE_URL=postgres://netpulse:changeme@localhost:5432/netpulse
#
# If DATABASE_URL is not set the app falls back to a SQLite file:
DB_PATH=data/monitor.db

# API Key for authenticating requests. Leave empty to disable auth (dev only).
API_KEY=change-me-to-a-random-secret

# Note: Router credentials (IP, Username, Password) are stored
# in the database via the /api/routers endpoint for
# Multi-MikroTik support.
